{
  "name": "stocksight-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && ..\\.venv\\\\Scripts\\\\python -m uvicorn src.main:app --reload --port 8000",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "build:client": "cd client && npm run build",
    "install:all": "npm install && cd client && npm install && cd ../server && ..\\\\.venv\\\\Scripts\\\\python -m pip install -r requirements.txt"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
